# Supabase
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Providers
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key
EXPO_PUBLIC_YOUCAM_API_KEY=your_youcam_api_key
EXPO_PUBLIC_YOUCAM_API_ENDPOINT=https://api.youcam.com/v1/analyze

# Security (dev only - NEVER commit these)
DEV_BYPASS=false
DEV_EMAIL=
DEV_PASSWORD=

# Production checklist before publishing:
# 1. Set EXPO_PUBLIC_DEV_BYPASS=false in production
# 2. Enable SSL certificate pinning (when supported)
# 3. Use expo-secure-store for sensitive credentials
# 4. Enable ProGuard/R8 code obfuscation
# 5. Set secure flag on all cookies
# 6. Implement certificate transparency loggingEXPO_PUBLIC_NIM_API_KEY=your_nvidia_nim_api_key_here
