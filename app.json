{
  "expo": {
    "name": "remake",
    "slug": "remake",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "remake",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.remake.ios",
      "buildNumber": "6",
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "REMAKE analyses your face and beauty products through your camera. Photos are never stored or shared.",
        "NSPhotoLibraryUsageDescription": "REMAKE lets you scan beauty products from photos in your library.",
        "NSLocationWhenInUseUsageDescription": "REMAKE reads your local UV index to recommend the right SPF protection for your makeup.",
        "NSUserNotificationsUsageDescription": "REMAKE sends one daily reminder so you never break your streak.",
        "NSUserTrackingUsageDescription": "This helps us understand if our ads are working. No face photos or personal data are ever used for tracking."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.remake.android",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBE8E3",
          "dark": {
            "backgroundColor": "#FBE8E3"
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-location",
      "expo-tracking-transparency",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.651518769892-jp8l89ckouivlfjf8rve8vi2veamkoh0"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "71f4735b-ba46-4279-b975-4e27b75d68a9"
      }
    },
    "owner": "remakeapp"
  }
}
